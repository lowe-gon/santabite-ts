{
  "name": "santabite-ts",
  "version": "1.0.0",
  "author": "Lowie Gonio (lowe.bg13@gmail.com)",
  "scripts": {
    "app:install": "pnpm install -r",
    "vendor:dev": "pnpm --prefix vendor-app start",
    "vendor:build": "pnpm --prefix vendor-app build",
    "vendor:ios": "pnpm --prefix vendor-app ios",
    "vendor:android": "pnpm --prefix vendor-app android",
    "customer:dev": "pnpm --prefix customer-app start",
    "customer:ios": "pnpm --prefix customer-app ios",
    "customer:android": "pnpm --prefix customer-app android",
    "driver:dev": "pnpm --prefix driver-app start",
    "driver:ios": "pnpm --prefix driver-app ios",
    "driver:android": "pnpm --prefix driver-app android",
    "web:dev": "pnpm --prefix vendor-app dev",
    "expo:lint": "pnpm --prefix vendor-app lint && pnpm --prefix driver-app lint && pnpm --prefix customer-app lint",
    "format": "pnpm --prefix vendor-app prettier:write && pnpm --prefix driver-app prettier:write && pnpm --prefix customer-app prettier:write",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
